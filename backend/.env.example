# App Configuration
PROJECT_NAME="Invora Inventory & Order Management"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Security
# Run 'openssl rand -hex 32' to generate a real secure key
SECRET_KEY="development_secret_key_change_me_in_production_1234567890"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="invora"

# Optional: Override the full Async URL directly
# DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/invora"

# CORS Configuration
# JSON-compatible list of origins: ["http://localhost:5173", "http://localhost:3000"]
BACKEND_CORS_ORIGINS='["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]'
